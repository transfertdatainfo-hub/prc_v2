// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// MODÈLES D'AUTHENTIFICATION
// ============================================================

// Utilisateur
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String?   // null pour les utilisateurs OAuth
  name              String?
  emailVerified     DateTime? @map("email_verified")
  image             String?
  role              String?    @default("free") // free, premium, admin
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  
  // Relations
  accounts          Account[]
  sessions          Session[]
  verificationTokens VerificationToken[]
  
  // Données existantes PRC
  rssFeeds          RSSFeed[]
  interestFilters   InterestFilter[]
  reports           Report[]
  backlogs          Backlog[]
  sprints           Sprint[]
  
  @@map("users")
}

// Comptes OAuth (Google, LinkedIn, etc.)
model Account {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  type              String
  provider          String
  providerAccountId String    @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Sessions utilisateur
model Session {
  id                String    @id @default(cuid())
  sessionToken      String    @unique @map("session_token")
  userId            String    @map("user_id")
  expires           DateTime
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

// Tokens de vérification (email, magic links, 2FA)
model VerificationToken {
  id                String    @id @default(cuid())
  identifier        String
  token             String
  expires           DateTime
  userId            String?   @map("user_id")
  
  user              User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// MODÈLES EXISTANTS PRC (inchangés, mais userId relié à User)
// ============================================================

// Table des sources (médias)
model Source {
  id        String    @id @default(cuid())
  name      String    @unique
  feeds     RSSFeed[]
  createdAt DateTime  @default(now()) @map("created_at")
  
  @@map("sources")
}

// Table des flux RSS (modifiée pour supporter l'arborescence)
model RSSFeed {
  id        String    @id @default(cuid())
  title     String
  url       String?
  userId    String    @map("user_id")
  sourceId  String?   @map("source_id")
  parentId  String?   @map("parent_id")
  nodeType  String    @default("feed") @map("node_type")
  createdAt DateTime  @default(now()) @map("created_at")
  
  // Relations
  source   Source?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  parent   RSSFeed?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children RSSFeed[] @relation("CategoryTree")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, url])
  @@map("rss_feeds")
}

// Table des filtres d'intérêts
model InterestFilter {
  id        String    @id @default(cuid())
  label     String
  userId    String    @map("user_id")
  blocks    Json?     // Stocke les blocs de mots-clés en JSON
  keywords  Keyword[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  
  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, label])
  @@map("interest_filters")
}

// Table des mots-clés pour les filtres
model Keyword {
  id        String         @id @default(cuid())
  word      String
  filterId  String         @map("filter_id")
  createdAt DateTime       @default(now()) @map("created_at")
  
  filter    InterestFilter @relation(fields: [filterId], references: [id], onDelete: Cascade)
  
  @@map("keywords")
}

// Table des rapports
model Report {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("reports")
}

// Backlogs (Product Backlog & Sprint Backlog items)
model Backlog {
  id          String    @id @default(cuid())
  title       String
  backlogType String    @default("task") @map("backlog_type")
  description String?   @db.Text
  position    Int       @default(0)
  parentId    String?   @map("parent_id")
  userId      String    @map("user_id")
  highlightColor String? @map("highlight_color")
  status      String    @default("draft")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  parent   Backlog?  @relation("BacklogTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Backlog[] @relation("BacklogTree")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  sprintItems SprintItem[]
  
  @@unique([userId, title, parentId])
  @@map("backlogs")
}

// Sprints
model Sprint {
  id        String       @id @default(cuid())
  name      String
  userId    String       @map("user_id")
  status    String       @default("active")
  items     SprintItem[]
  createdAt DateTime     @default(now()) @map("created_at")
  endedAt   DateTime?    @map("ended_at")
  
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sprints")
}

// Items d'un sprint (relation many-to-many entre Sprint et Backlog)
model SprintItem {
  id        String   @id @default(cuid())
  sprintId  String   @map("sprint_id")
  backlogId String   @map("backlog_id")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  
  sprint  Sprint  @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  backlog Backlog @relation(fields: [backlogId], references: [id], onDelete: Cascade)
  
  @@unique([sprintId, backlogId])
  @@map("sprint_items")
}