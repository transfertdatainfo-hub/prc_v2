// prisma\schema.prisma

// prisma/schema.prisma
generator client {
  provider = "prisma-client-js" // Important : c'est "-js" en v5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // L'URL revient dans le schéma
}

// VOS MODÈLES RESTENT EXACTEMENT LES MÊMES
model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  rssFeeds        RSSFeed[]
  interestFilters InterestFilter[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Source {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  
  // Relations
  feeds     RSSFeed[]  // Un source peut avoir plusieurs flux RSS
}

model RSSFeed {
  id        String   @id @default(cuid())
  title     String
  url       String   @unique
  sourceId  String?
  userId    String
  createdAt DateTime @default(now())
  
  // Relations
  source    Source?  @relation(fields: [sourceId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

// NOUVEAU : Modèle pour les filtres d'intérêts personnalisés
model InterestFilter {
  id        String    @id @default(cuid())
  label     String // Ex: "Enrôlement Canada", "Guerre Ukraine"
  userId    String // Pour plus tard quand tu auras l'auth
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords  Keyword[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, label]) // Évite les doublons de nom pour un même user
  @@map("interest_filters")
}

// NOUVEAU : Modèle pour les mots-clés associés à un filtre
model Keyword {
  id        String         @id @default(cuid())
  word      String // Le mot-clé lui-même
  filterId  String
  filter    InterestFilter @relation(fields: [filterId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([filterId, word]) // Évite les doublons de mots-clés dans un même filtre
  @@map("keywords")
}
