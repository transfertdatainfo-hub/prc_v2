// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Table des sources (médias)
model Source {
  id        String    @id @default(cuid())
  name      String    @unique
  feeds     RSSFeed[]
  createdAt DateTime  @default(now()) @map("created_at")
  
  @@map("sources")
}

// Table des flux RSS (modifiée pour supporter l'arborescence)
model RSSFeed {
  id        String    @id @default(cuid())
  title     String
  url       String?
  userId    String    @map("user_id")
  sourceId  String?   @map("source_id")
  parentId  String?   @map("parent_id")
  nodeType  String    @default("feed") @map("node_type")
  createdAt DateTime  @default(now()) @map("created_at")
  
  // Relations
  source   Source?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  parent   RSSFeed?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children RSSFeed[] @relation("CategoryTree")
  
  @@unique([userId, url])
  @@map("rss_feeds")
}

// Table des filtres d'intérêts
model InterestFilter {
  id        String    @id @default(cuid())
  label     String
  userId    String    @map("user_id")
  blocks    Json?     // Stocke les blocs de mots-clés en JSON (structure: [{ id, keywords, isExclusion }])
  keywords  Keyword[] // Gardé pour compatibilité avec l'ancien système
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  
  @@unique([userId, label])
  @@map("interest_filters")
}

// Table des mots-clés pour les filtres (conservée pour compatibilité)
model Keyword {
  id        String         @id @default(cuid())
  word      String
  filterId  String         @map("filter_id")
  createdAt DateTime       @default(now()) @map("created_at")
  
  filter    InterestFilter @relation(fields: [filterId], references: [id], onDelete: Cascade)
  
  @@map("keywords")
}

// Table des rapports (pour plus tard)
model Report {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  
  @@map("reports")
}


model Backlog {
  id          String    @id @default(cuid())
  title       String
  backlogType String    @default("task") @map("backlog_type")
  description String?   @db.Text
  position    Int       @default(0)
  parentId    String?   @map("parent_id")
  userId      String    @map("user_id")
  highlightColor String? @map("highlight_color")
  status      String    @default("draft")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  parent   Backlog?  @relation("BacklogTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Backlog[] @relation("BacklogTree")
  
  sprintItems SprintItem[]
  
  @@unique([userId, title, parentId])
  @@map("backlogs")
}

model Sprint {
  id        String       @id @default(cuid())
  name      String
  userId    String       @map("user_id")
  status    String       @default("active")
  items     SprintItem[]
  createdAt DateTime     @default(now()) @map("created_at")
  endedAt   DateTime?    @map("ended_at")
  
  @@map("sprints")
}

model SprintItem {
  id        String   @id @default(cuid())
  sprintId  String   @map("sprint_id")
  backlogId String   @map("backlog_id")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  
  sprint  Sprint  @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  backlog Backlog @relation(fields: [backlogId], references: [id], onDelete: Cascade)
  
  @@unique([sprintId, backlogId])
  @@map("sprint_items")
}